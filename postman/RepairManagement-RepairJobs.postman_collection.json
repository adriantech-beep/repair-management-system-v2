    {
      "name": "9. Update Repair Job",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
