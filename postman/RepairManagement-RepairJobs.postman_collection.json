    {
      "name": "8. Get Repair Jobs by Branch - Status Filter (Received)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('All returned jobs have status Received', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "    body.forEach(function(job) {",
              "        pm.expect(job.status).to.eql('Received');",
              "    });",
              "});"
            ]
          }
        }
      ],
