{
  "info": {
    "name": "Repair Management - RepairJobs v1",
    "description": "RepairJob CRUD regression suite. Run requests top to bottom after importing the Dev environment. Requires Admin JWT in {{accessToken}}, valid {{branchId}}, {{customerId}}, and {{deviceId}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login as Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Admin tokens are saved', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.accessToken).to.be.a('string').and.not.be.empty;",
              "    pm.environment.set('accessToken', body.accessToken);",
              "    pm.environment.set('refreshToken', body.refreshToken);",
              "    const branchFromUser = body.user && body.user.branchId ? body.user.branchId : null;",
              "    if (branchFromUser) {",
              "        pm.environment.set('branchId', branchFromUser);",
              "    }",
              "});",
              "",
              "pm.test('Branch ID is available', function () {",
              "    const branchId = pm.environment.get('branchId');",
              "    pm.expect(branchId, 'Set branchId in environment OR assign a BranchId to your admin user in DB').to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test('Customer ID is available', function () {",
              "    const customerId = pm.environment.get('customerId');",
              "    pm.expect(customerId, 'Run the Customers collection first to populate customerId').to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test('Device ID is available', function () {",
              "    const deviceId = pm.environment.get('deviceId');",
              "    pm.expect(deviceId, 'Run the Devices collection first to populate deviceId').to.be.a('string').and.not.be.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@repairmanagement.local\",\n  \"password\": \"AdminPassword123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "2. Create Repair Job (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('RepairJob ID is saved', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.id).to.be.a('string').and.not.be.empty;",
              "    pm.expect(body.problemDescription).to.eql('Screen cracked');",
              "    pm.expect(body.status).to.eql('Received');",
              "    pm.environment.set('repairJobId', body.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"deviceId\": \"{{deviceId}}\",\n  \"branchId\": \"{{branchId}}\",\n  \"problemDescription\": \"Screen cracked\",\n  \"estimatedCost\": 150.00\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/repair-jobs",
          "host": ["{{baseUrl}}"],
          "path": ["api", "repair-jobs"]
        }
      }
    },
