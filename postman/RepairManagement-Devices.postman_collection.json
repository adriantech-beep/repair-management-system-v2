{
  "info": {
    "name": "Repair Management - Devices v1",
    "description": "Device CRUD regression suite. Run requests top to bottom after importing the Dev environment. Requires Admin JWT in {{accessToken}}, valid {{branchId}}, and valid {{customerId}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login as Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Admin tokens are saved', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.accessToken).to.be.a('string').and.not.be.empty;",
              "    pm.environment.set('accessToken', body.accessToken);",
              "    pm.environment.set('refreshToken', body.refreshToken);",
              "    const branchFromUser = body.user && body.user.branchId ? body.user.branchId : null;",
              "    if (branchFromUser) {",
              "        pm.environment.set('branchId', branchFromUser);",
              "    }",
              "});",
              "",
              "pm.test('Branch ID is available', function () {",
              "    const branchId = pm.environment.get('branchId');",
              "    pm.expect(branchId, 'Set branchId in environment OR assign a BranchId to your admin user in DB').to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "pm.test('Customer ID is available', function () {",
              "    const customerId = pm.environment.get('customerId');",
              "    pm.expect(customerId, 'Run the Customers collection first to populate customerId').to.be.a('string').and.not.be.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@repairmanagement.local\",\n  \"password\": \"AdminPassword123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "2. Create Device (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Device ID is saved', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.id).to.be.a('string').and.not.be.empty;",
              "    pm.expect(body.brand).to.eql('Apple');",
              "    pm.expect(body.model).to.eql('iPhone 14');",
              "    pm.environment.set('deviceId', body.id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"branchId\": \"{{branchId}}\",\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 14\",\n  \"serialNumber\": \"SN-TEST-001\",\n  \"deviceType\": \"Mobile\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/devices",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices"]
        }
      }
    },
    {
      "name": "3. Create Device - Customer Not Found (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"00000000-0000-0000-0000-000000000000\",\n  \"branchId\": \"{{branchId}}\",\n  \"brand\": \"Samsung\",\n  \"model\": \"Galaxy S22\",\n  \"deviceType\": \"Mobile\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/devices",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices"]
        }
      }
    },
    {
      "name": "4. Get Devices by Customer ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is an array with at least 1 device', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.be.an('array');",
              "    pm.expect(body.length).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/devices/customer/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices", "customer", "{{customerId}}"]
        }
      }
    },
    {
      "name": "5. Get Device by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Device ID matches', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.id).to.eql(pm.environment.get('deviceId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/devices/{{deviceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices", "{{deviceId}}"]
        }
      }
    },
    {
      "name": "6. Get Device by ID - Not Found (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 404 Not Found', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/devices/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices", "00000000-0000-0000-0000-000000000000"]
        }
      }
    },
    {
      "name": "7. Update Device (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Device is updated', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body.brand).to.eql('Samsung');",
              "    pm.expect(body.model).to.eql('Galaxy S23');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"brand\": \"Samsung\",\n  \"model\": \"Galaxy S23\",\n  \"serialNumber\": \"SN-UPDATED-001\",\n  \"deviceType\": \"Mobile\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/devices/{{deviceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices", "{{deviceId}}"]
        }
      }
    },
    {
      "name": "8. Delete Device (Happy Path)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 204 No Content', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/devices/{{deviceId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices", "{{deviceId}}"]
        }
      }
    },
    {
      "name": "9. Create Device - No Auth (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401 Unauthorized', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"branchId\": \"{{branchId}}\",\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 14\",\n  \"deviceType\": \"Mobile\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/devices",
          "host": ["{{baseUrl}}"],
          "path": ["api", "devices"]
        }
      }
    }
  ]
}
